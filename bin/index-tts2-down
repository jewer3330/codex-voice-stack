#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
codex_home="$(cd "${script_dir}/.." && pwd)"
server_root="${CODEX_SERVER_ROOT:-/Volumes/ssd/servers}"
service_root="${VOICE_TTS_HOME:-${server_root}/voice-tts}"
pid_file="$service_root/index-tts2.pid"
script="${CODEX_INDEX_TTS2_SERVICE:-${codex_home}/bin/index-tts2-service.py}"

find_service_pids() {
  ps -axo pid=,stat=,command= | awk -v script="$script" -v self="$$" '
    $1 != self && $2 !~ /Z/ && index($0, script) {
      print $1
    }
  '
}

if [[ -f "$pid_file" ]]; then
  pid="$(cat "$pid_file")"
  if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
    kill "$pid" >/dev/null 2>&1 || true
    for _ in {1..80}; do
      if ! kill -0 "$pid" >/dev/null 2>&1 || ps -p "$pid" -o stat= | grep -q Z; then
        break
      fi
      sleep 0.1
    done
  fi
  rm -f "$pid_file"
fi

pids="$(find_service_pids)"
if [[ -n "$pids" ]]; then
  while IFS= read -r service_pid; do
    [[ -n "$service_pid" ]] && kill "$service_pid" >/dev/null 2>&1 || true
  done <<<"$pids"
fi

for _ in {1..80}; do
  remaining="$(find_service_pids)"
  [[ -z "$remaining" ]] && break
  sleep 0.1
done

remaining="$(find_service_pids)"
if [[ -n "$remaining" ]]; then
  while IFS= read -r service_pid; do
    [[ -n "$service_pid" ]] && kill -9 "$service_pid" >/dev/null 2>&1 || true
  done <<<"$remaining"
fi

echo "IndexTTS2 service stopped"
