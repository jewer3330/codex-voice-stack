#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${CODEX_HOME:-}" ]]; then
  CODEX_HOME="$(cd "${SCRIPT_DIR}/.." && pwd)"
fi
if [[ -z "${CODEX_SERVER_ROOT:-}" ]]; then
  if [[ "$CODEX_HOME" == */work/.codex ]]; then
    CODEX_SERVER_ROOT="$(cd "${CODEX_HOME}/../.." && pwd)/servers"
  else
    CODEX_SERVER_ROOT="${CODEX_HOME}/servers"
  fi
fi

LISTENER_HOME="${CODEX_VOICE_LISTENER_HOME:-${CODEX_SERVER_ROOT}/codex-voice-listener}"
LOG_DIR="${LISTENER_HOME}/logs"
mkdir -p "$LOG_DIR"

tail -n "${CODEX_VOICE_LISTENER_LOG_TAIL:-120}" -f \
  "${LOG_DIR}/listener.log" \
  "${LOG_DIR}/listener.err.log"
