#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${CODEX_HOME:-}" ]]; then
  CODEX_HOME="$(cd "${SCRIPT_DIR}/.." && pwd)"
fi
if [[ -z "${CODEX_SERVER_ROOT:-}" ]]; then
  if [[ "$CODEX_HOME" == */work/.codex ]]; then
    CODEX_SERVER_ROOT="$(cd "${CODEX_HOME}/../.." && pwd)/servers"
  else
    CODEX_SERVER_ROOT="${CODEX_HOME}/servers"
  fi
fi
export CODEX_HOME CODEX_SERVER_ROOT

LISTENER_HOME="${CODEX_VOICE_LISTENER_HOME:-${CODEX_SERVER_ROOT}/codex-voice-listener}"
PYTHON_BIN="${CODEX_VOICE_LISTENER_PYTHON_BIN:-${LISTENER_HOME}/.venv/bin/python}"

if [[ ! -x "$PYTHON_BIN" ]]; then
  help_requested=0
  for arg in "$@"; do
    if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
      help_requested=1
    fi
  done
  if [[ "${1:-}" == "doctor" || "$help_requested" == "1" ]]; then
    exec "${PYTHON:-python3}" "$SCRIPT_DIR/codex_realtimestt_listener.py" "$@"
  fi
  echo "codex-voice-listener: runtime not found at $PYTHON_BIN" >&2
  echo "Run codex-voice-listener-setup first." >&2
  exit 1
fi

exec "$PYTHON_BIN" "$SCRIPT_DIR/codex_realtimestt_listener.py" "$@"
