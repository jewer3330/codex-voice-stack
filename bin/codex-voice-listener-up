#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${CODEX_HOME:-}" ]]; then
  CODEX_HOME="$(cd "${SCRIPT_DIR}/.." && pwd)"
fi
if [[ -z "${CODEX_SERVER_ROOT:-}" ]]; then
  if [[ "$CODEX_HOME" == */work/.codex ]]; then
    CODEX_SERVER_ROOT="$(cd "${CODEX_HOME}/../.." && pwd)/servers"
  else
    CODEX_SERVER_ROOT="${CODEX_HOME}/servers"
  fi
fi
export CODEX_HOME CODEX_SERVER_ROOT

LISTENER_HOME="${CODEX_VOICE_LISTENER_HOME:-${CODEX_SERVER_ROOT}/codex-voice-listener}"
LOG_DIR="${LISTENER_HOME}/logs"
PID_FILE="${LISTENER_HOME}/listener.pid"
mkdir -p "$LOG_DIR" "${LISTENER_HOME}/data"

if [[ -f "$PID_FILE" ]]; then
  old_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
    echo "codex voice listener already running: $old_pid"
    exit 0
  fi
fi

nohup "${CODEX_HOME}/bin/codex-voice-listener" listen-loop "$@" \
  >>"${LOG_DIR}/listener.log" \
  2>>"${LOG_DIR}/listener.err.log" &
pid="$!"
printf '%s\n' "$pid" >"$PID_FILE"
echo "codex voice listener started: $pid"
