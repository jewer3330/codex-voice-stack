#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -z "${CODEX_HOME:-}" ]]; then
  CODEX_HOME="$(cd "${SCRIPT_DIR}/.." && pwd)"
fi
if [[ -z "${CODEX_SERVER_ROOT:-}" ]]; then
  if [[ "$CODEX_HOME" == */work/.codex ]]; then
    CODEX_SERVER_ROOT="$(cd "${CODEX_HOME}/../.." && pwd)/servers"
  else
    CODEX_SERVER_ROOT="${CODEX_HOME}/servers"
  fi
fi

LISTENER_HOME="${CODEX_VOICE_LISTENER_HOME:-${CODEX_SERVER_ROOT}/codex-voice-listener}"
PID_FILE="${LISTENER_HOME}/listener.pid"
STATE_FILE="${LISTENER_HOME}/data/state.json"

if [[ -f "$PID_FILE" ]]; then
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    echo "running: $pid"
  else
    echo "stale pid: ${pid:-unknown}"
  fi
else
  echo "stopped"
fi

if [[ -f "$STATE_FILE" ]]; then
  cat "$STATE_FILE"
fi
